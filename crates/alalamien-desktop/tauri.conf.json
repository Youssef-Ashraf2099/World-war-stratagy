{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Alalamien War",
  "version": "0.1.0",
  "identifier": "com.alalamien.war",
  "build": {
    "beforeDevCommand": "cd ../../frontend && npm run dev",
    "beforeBuildCommand": "cd ../../frontend && npm run build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../../frontend/dist"
  },
  "app": {
    "windows": [
      {
        "title": "Alalamien War",
        "width": 1600,
        "height": 900,
        "resizable": true,
        "fullscreen": false,
        "minWidth": 1280,
        "minHeight": 720
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false,
    "targets": "all",
    "icon": []
  }
}
